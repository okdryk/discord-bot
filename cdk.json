{
  "app": "python3 app.py",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "requirements*.txt", "**/__pycache__", "tests", "plans", ".venv"]
  },
  "context": {
    "instance_id": "REPLACE_WITH_PALWORLD_EC2_INSTANCE_ID",
    "param_prefix": "/palworld",
